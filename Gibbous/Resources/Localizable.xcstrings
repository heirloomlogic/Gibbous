    "about.homage" : {
      "comment" : "Credit line naming the two original apps Gibbous pays tribute to and the library it is built on. Keep the names \"Moontool\", \"Moon Tool\", \"John Walker\", \"Richard Knuckey\", and \"AstronomyKit\" as-is; the year 1988 refers to the original Moontool, and the year 1994 refers to the original Moon Tool.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Hommage an Moontool von John Walker (1988) und das Macintosh Moon Tool von Richard Knuckey. Basiert auf AstronomyKit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An homage to Moontool by John Walker (1988) and the Macintosh Moon Tool by Richard Knuckey. Built on AstronomyKit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un homenaje a Moontool de John Walker (1988) y al Macintosh Moon Tool de Richard Knuckey. Construido sobre AstronomyKit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un hommage à Moontool de John Walker (1988) et au Macintosh Moon Tool de Richard Knuckey. Conçu avec AstronomyKit."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un omaggio a Moontool di John Walker (1988) e al Macintosh Moon Tool di Richard Knuckey. Realizzato con AstronomyKit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "John Walker による Moontool（1988年）と Richard Knuckey による Macintosh Moon Tool へのオマージュ。AstronomyKit を使って構築。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "John Walker의 Moontool(1988)과 Richard Knuckey의 Macintosh Moon Tool에 대한 오마주. AstronomyKit으로 제작되었습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een eerbetoon aan Moontool van John Walker (1988) en de Macintosh Moon Tool van Richard Knuckey. Gebouwd op AstronomyKit."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma homenagem ao Moontool de John Walker (1988) e ao Macintosh Moon Tool de Richard Knuckey. Desenvolvido com o AstronomyKit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дань уважения Moontool от John Walker (1988) и Macintosh Moon Tool от Richard Knuckey. Создано на основе AstronomyKit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "向 John Walker 的 Moontool（1988 年）和 Richard Knuckey 的 Macintosh Moon Tool 致敬。基于 AstronomyKit 构建。"
          }
        }
      }
    },
    "about.observatory.edict" : {
      "comment" : "Contemplative line introducing the sibling app Edict, shown as its own line below the Fallow line. Keep the product name \"Edict\" as-is.",
      "localizations" : {
